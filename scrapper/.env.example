# ── Postgres ────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=saflow
POSTGRES_PASSWORD=saflow
POSTGRES_DB=scrapper
DATABASE_URL=postgresql+psycopg://saflow:saflow@localhost:5432/scrapper

# ── Scraper behaviour ───────────────────────────────────────
# Random delay range between actions (seconds)
MIN_DELAY_S=2.0
MAX_DELAY_S=7.0
# Cap on results per single Google Maps query (saves time on dense cities)
MAX_RESULTS_PER_QUERY=120
# Headed browser is useful for debugging selectors; headless for production
HEADLESS=true
# Optional proxy. Format: http://user:pass@host:port
HTTP_PROXY=

# ── Enrichment ──────────────────────────────────────────────
# Max pages per business website to crawl for emails
ENRICH_MAX_PAGES=4
# HTTP timeout per page (seconds)
ENRICH_HTTP_TIMEOUT=15
# Comma-separated list of contact-page paths to try beyond the home page
ENRICH_PATHS=/contact,/contact-us,/about,/about-us,/team,/imprint

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
